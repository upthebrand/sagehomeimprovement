# Optional: Google Tag Manager container ID (loads one script; configure GA4, Ads, Clarity, etc. inside GTM).
# PUBLIC_GTM_CONTAINER_ID=GTM-XXXXXXX

# Hero video: set A only for a single clip, or A + B for a simple 50/50 client-side split (session-sticky).
# Clarity custom tag "hero_video" = "a" | "b"; also pushes dataLayer event "hero_video_variant" for GTM.
# PUBLIC_HERO_VIDEO_A=https://your-cdn.com/hero-a.mp4
# PUBLIC_HERO_VIDEO_B=https://your-cdn.com/hero-b.mp4
