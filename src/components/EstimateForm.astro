---
interface Props {
	variant?: 'page' | 'sidebar';
}

const { variant = 'page' } = Astro.props;
const isSidebar = variant === 'sidebar';

const inputClass =
	'mt-1 w-full rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-charcoal shadow-sm outline-none transition placeholder:text-stone-400 focus:border-sage-500 focus:ring-2 focus:ring-sage-500/25';
const labelClass = 'estimate-field-label block text-sm font-medium text-charcoal';
---

<section
	id="estimate"
	class:list={[
		'scroll-mt-20',
		isSidebar ? 'lg:scroll-mt-24' : 'px-4 py-10 sm:px-6',
	]}
	aria-labelledby="estimate-title"
>
	<div
		class:list={[
			'estimate-surface rounded-2xl border border-stone-200 bg-white p-5 shadow-sm sm:p-8',
			!isSidebar && 'mx-auto max-w-lg sm:max-w-2xl',
		]}
	>
			<h2 id="estimate-title" class="text-xl font-bold tracking-tight text-charcoal sm:text-2xl">
				Let’s Set Up Your Free Estimate
			</h2>
			<p class="estimate-muted mt-1 text-sm text-stone-600 sm:text-base">
				Residential service only. Quick call, quick visit, zero pressure
			</p>

			<form
				class="mt-6 space-y-4"
				name="estimate"
				method="POST"
				data-netlify="true"
				netlify-honeypot="bot-field"
				action="/" netlify
			>
				<input type="hidden" name="form-name" value="estimate" />

				<p class="hidden" aria-hidden="true">
					<label>
						Do not fill this in if you are human:
						<input name="bot-field" tabindex="-1" autocomplete="off" />
					</label>
				</p>

				<div>
					<label for="est-fullname" class={labelClass}>Full name</label>
					<input
						id="est-fullname"
						name="fullname"
						type="text"
						required
						autocomplete="name"
						class={inputClass}
					/>
				</div>

				<div>
					<label for="est-phone" class={labelClass}>Phone</label>
					<input
						id="est-phone"
						name="phone"
						type="tel"
						required
						autocomplete="tel"
						placeholder="555-0199"
						class={inputClass}
					/>
				</div>

				<div>
					<label for="est-address" class={labelClass}>Service address</label>
					<input
						id="est-address"
						name="service_address"
						type="text"
						required
						autocomplete="street-address"
						class={inputClass}
					/>
				</div>

				<div>
					<label for="est-date" class={labelClass}>Preferred date</label>
					<input id="est-date" name="preferred_date" type="date" class={inputClass} />
					<p class="estimate-muted mt-1 text-xs text-stone-500">
						Optional (use the browser date picker)
					</p>
				</div>

				<fieldset>
					<legend class={labelClass}>Service type (select all that apply)</legend>
					<div class="mt-2 flex flex-wrap gap-4">
						<label class="estimate-choice flex cursor-pointer items-center gap-2 text-sm text-charcoal">
							<input
								type="checkbox"
								name="service_types"
								value="Windows"
								class="size-4 border-stone-300 text-sage-600 focus:ring-sage-500"
							/>
							Windows
						</label>
						<label class="estimate-choice flex cursor-pointer items-center gap-2 text-sm text-charcoal">
							<input
								type="checkbox"
								name="service_types"
								value="Entry Doors"
								class="size-4 border-stone-300 text-sage-600 focus:ring-sage-500"
							/>
							Entry Doors
						</label>
						<label class="estimate-choice flex cursor-pointer items-center gap-2 text-sm text-charcoal">
							<input
								type="checkbox"
								name="service_types"
								value="Storm Doors"
								class="size-4 border-stone-300 text-sage-600 focus:ring-sage-500"
							/>
							Storm Doors
						</label>
						<label class="estimate-choice flex cursor-pointer items-center gap-2 text-sm text-charcoal">
							<input
								type="checkbox"
								name="service_types"
								value="Other"
								class="size-4 border-stone-300 text-sage-600 focus:ring-sage-500"
							/>
							Other
						</label>
					</div>
				</fieldset>

				<button
					type="submit"
					class="estimate-submit w-full rounded-lg bg-sage-600 py-3 text-base font-semibold text-white shadow-sm transition-colors duration-300 hover:bg-sage-700"
				>
					Get My Free Estimate
				</button>
				<p class="estimate-muted text-pretty text-center text-xs leading-relaxed text-stone-500">
					Trust is important. Sage will never sell your data.{' '}
					<button
						type="button"
						class="font-semibold text-sage-700 underline decoration-sage-600/30 underline-offset-2 transition hover:text-sage-800 hover:decoration-sage-700/50"
						data-legal-open="privacy"
					>
						Privacy policy
					</button>
					.
				</p>
			</form>
	</div>
</section>

<script is:inline>
	(function () {
		var el = document.getElementById('est-date');
		if (!el || !(el instanceof HTMLInputElement)) return;
		if (el.value) return;

		var d = new Date();
		var y = String(d.getFullYear());
		var m = String(d.getMonth() + 1).padStart(2, '0');
		var day = String(d.getDate()).padStart(2, '0');
		el.value = y + '-' + m + '-' + day;
	})();
</script>
