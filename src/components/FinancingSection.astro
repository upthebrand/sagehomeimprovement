---
import { financingApplyUrl, financingPartnerName } from '../data/financing';

const highlights = [
	'Monthly payment options for qualified homeowners',
	'Soft credit checks available from lending partners (see partner site)',
	'Loan amounts and rates depend on your credit review',
	'Options for a wide range of credit profiles after you apply',
] as const;
---

<section
	id="financing"
	class="scroll-mt-20 px-4 py-12 sm:px-6 sm:py-16"
	aria-labelledby="financing-title"
>
	<div
		class="mx-auto max-w-3xl overflow-hidden rounded-2xl border border-sage-200 bg-gradient-to-br from-sage-50 via-white to-sage-50/80 p-6 shadow-sm ring-1 ring-sage-100 sm:p-10"
	>
		<p class="text-sm font-semibold uppercase tracking-wide text-sage-700">New at Sage</p>
		<h2 id="financing-title" class="mt-2 text-2xl font-bold tracking-tight text-charcoal sm:text-3xl">
			Financing is now available
		</h2>
		<p class="mt-3 text-base leading-relaxed text-stone-700">
			Sage Home Improvements accepts financing through our partner, {financingPartnerName}. Spread the cost of
			windows and doors into manageable monthly payments instead of paying everything upfront.
		</p>

		<ul class="mt-6 space-y-3 text-sm leading-relaxed text-stone-700 sm:text-base">
			{
				highlights.map((text) => (
					<li class="flex gap-3">
						<span
							class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full bg-sage-600 text-xs font-bold text-white"
							aria-hidden="true"
						>
							✓
						</span>
						<span>{text}</span>
					</li>
				))
			}
		</ul>

		<div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
			<a
				href={financingApplyUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex w-full items-center justify-center rounded-lg bg-sage-600 px-4 py-3 text-center text-sm font-semibold text-white shadow-sm transition hover:bg-sage-700 sm:w-auto"
			>
				Check financing options
			</a>
			<a
				href="#estimate"
				class="inline-flex w-full items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-3 text-center text-sm font-semibold text-charcoal shadow-sm transition hover:bg-stone-50 sm:w-auto"
			>
				Get a free in-home estimate first
			</a>
		</div>

		<p class="mt-6 text-xs leading-relaxed text-stone-500">
			You will leave sagehomeimprove.com and complete a secure application on 
			<a
				href={financingApplyUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="text-charcoal hover:text-sage-500 underline font-bold"
			>{financingPartnerName}
			</a>.
			
			Rates,
			terms, and approval are set by lending partners based on your creditworthiness and other factors. Sage does
			not make credit decisions. Financing is for Sage Home Improvements projects only.
		</p>
	</div>
</section>
