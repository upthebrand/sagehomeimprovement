---
import { gtmContainerId as gtmFromSite } from '../data/site';

interface Props {
	placement: 'head' | 'body';
}

const { placement } = Astro.props;
const fromEnv = (
	process.env.PUBLIC_GTM_CONTAINER_ID ??
	process.env.GTM_CONTAINER_ID ??
	import.meta.env.PUBLIC_GTM_CONTAINER_ID ??
	''
).trim();
const containerId = fromEnv || String(gtmFromSite ?? '').trim();
const gtmIdOk = /^GTM-[A-Z0-9]+$/i.test(containerId);

const gtmHeadHtml = gtmIdOk
	? `<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${containerId}');</script>
<!-- End Google Tag Manager -->`
	: '';

const gtmBodyHtml = gtmIdOk
	? `<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=${containerId}"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->`
	: '';
---

{placement === 'head' && gtmIdOk && <Fragment set:html={gtmHeadHtml} />}

{placement === 'body' && gtmIdOk && <Fragment set:html={gtmBodyHtml} />}
