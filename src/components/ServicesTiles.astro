---
const tiles = [
	{
		title: 'Window Replacement',
		priceLine: 'Starting at $495 Installation Included',
		body: 'Energy-efficient vinyl, wood-clad, and composite options with professional installation and clean job sites.',
		href: '#estimate',
		cta: 'Get an Estimate',
	},
	{
		title: 'Entry Door Replacement',
		priceLine: 'Starting at $1200 Installation Included',
		body: 'Entry doors that fit your opening, swing correctly, and lock solid. Sage dials in the insulation, weatherstripping, and hardware.',
		href: '#estimate',
		cta: 'Get an Estimate',
	},
	{
		title: 'Storm Door Replacement',
		priceLine: 'Starting at $999 Installation Included',
		body: 'Full-view, ventilating, and security storm options to protect your entry and improve comfort year-round.',
		href: '#estimate',
		cta: 'Get an Estimate',
	},
	{
		title: 'Patio Doors',
		priceLine: 'Starting at $1200 Installation Included',
		body: 'Sliding and swinging patio units with smooth tracks, proper drainage, and weather-tight seals against drafts and leaks.',
		href: '#estimate',
		cta: 'Get an Estimate',
	},
	{
		title: 'Bay & Bow Windows',
		priceLine: 'Starting at $2000 Installation Included',
		body: 'Bay and bow layouts that bring in more light and more view. Custom sized and flashed for a tight seal.',
		href: '#estimate',
		cta: 'Get an Estimate',
	},
	{
		title: 'Free consultation',
		priceLine: 'Complimentary visit · Written quote included',
		body: 'On-site measurements, product samples, and a clear written quote. No pressure and no surprises.',
		href: '#estimate',
		cta: 'Schedule a Visit',
	},
] as const;
---

<section id="services" class="scroll-mt-20 px-4 py-10 sm:px-6" aria-labelledby="services-tiles-title">
	<div class="mx-auto w-full max-w-3xl text-center">
		<h2 id="services-tiles-title" class="text-xl font-bold tracking-tight text-charcoal sm:text-2xl">
			Services
		</h2>
		<p class="mx-auto mt-2 max-w-2xl text-sm text-stone-600 sm:text-base">
			Windows and doors, handled start to finish for the Greater Baltimore Area. Simple, clean, and done right.
		</p>
		<ul class="mt-8 flex w-full flex-col gap-4">
			{
				tiles.map(({ title, priceLine, body, href, cta }) => (
					<li class="flex w-full flex-col rounded-2xl border border-white/15 bg-sage-600 p-6 text-center shadow-sm ring-1 ring-white/10 sm:p-8">
						<h3 class="text-lg font-semibold text-white">{title}</h3>
						<p class="mt-2 text-sm font-semibold text-white">{priceLine}</p>
						<p class="mx-auto mt-3 max-w-2xl flex-1 text-sm leading-relaxed text-white/90">{body}</p>
						<a
							href={href}
							class="mt-5 inline-flex justify-center text-sm font-semibold text-white underline decoration-white/40 underline-offset-2 transition hover:text-white hover:decoration-white/70"
						>
							{cta}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
