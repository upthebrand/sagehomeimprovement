---
import { privacyParagraphs, termsParagraphs } from '../data/legal';
import { galleryPhotos } from '../data/gallery';
---

<div class="hidden" aria-hidden="true">
	<div id="tpl-success-root" class="space-y-3 text-center">
		<p class="text-xl font-bold text-charcoal">Thank You</p>
		<p class="text-sm leading-relaxed text-stone-600">
			The request went through. Someone from Sage will reach out soon. For anything urgent, use the phone number in
			the footer.
		</p>
	</div>
	<div id="tpl-privacy-root" class="space-y-3 text-sm leading-relaxed text-stone-600">
		{privacyParagraphs.map((p) => <p>{p}</p>)}
	</div>
	<div id="tpl-terms-root" class="space-y-3 text-sm leading-relaxed text-stone-600">
		{termsParagraphs.map((p) => <p>{p}</p>)}
	</div>
</div>

<script type="application/json" id="site-modal-gallery-data" set:html={JSON.stringify(galleryPhotos)} />

<dialog
	id="site-modal"
	class="site-modal-dialog fixed inset-0 z-[200] overflow-visible"
	aria-labelledby="site-modal-title"
>
	<div
		class="absolute inset-0 z-0 cursor-default"
		data-site-modal-backdrop
		role="presentation"
	></div>
	<div
		class="site-modal-panel relative z-10 max-h-[90vh] w-full max-w-4xl overflow-y-auto rounded-2xl border border-stone-200 bg-white p-6 shadow-2xl sm:p-8"
		role="document"
	>
		<button
			type="button"
			class="absolute right-3 top-3 z-50 flex size-12 items-center justify-center rounded-full bg-sage-600 text-2xl font-bold leading-none text-white shadow-md transition hover:bg-sage-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sage-600 active:scale-95"
			data-site-modal-close
			aria-label="Close dialog"
		>
			×
		</button>
		<h2 id="site-modal-title" class="pr-10 text-xl font-bold text-charcoal sm:text-2xl"></h2>
		<div id="site-modal-body" class="mt-4"></div>
		<div
			id="site-modal-gallery-nav"
			class="mt-6 hidden flex flex-wrap items-center justify-between gap-4 border-t border-stone-200 pt-4"
		>
			<button
				type="button"
				class="rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-charcoal transition hover:bg-stone-50"
				data-gallery-prev
			>
				Previous
			</button>
			<span id="site-modal-gallery-counter" class="text-sm font-medium text-stone-600"></span>
			<button
				type="button"
				class="rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-charcoal transition hover:bg-stone-50"
				data-gallery-next
			>
				Next
			</button>
		</div>
	</div>
</dialog>

<script>
	function initSiteModal() {
		const dialog = document.getElementById('site-modal');
		const titleEl = document.getElementById('site-modal-title');
		const bodyEl = document.getElementById('site-modal-body');
		const navEl = document.getElementById('site-modal-gallery-nav');
		const counterEl = document.getElementById('site-modal-gallery-counter');
		const jsonEl = document.getElementById('site-modal-gallery-data');
		if (!dialog || !titleEl || !bodyEl || !navEl || !counterEl || !(dialog instanceof HTMLDialogElement)) return;

		let gallery = [];
		try {
			gallery = JSON.parse(jsonEl?.textContent || '[]');
		} catch {
			gallery = [];
		}
		let galleryIndex = 0;

		function cloneTpl(id) {
			const root = document.getElementById(id);
			const frag = document.createDocumentFragment();
			if (!root) return frag;
			for (const node of root.childNodes) {
				frag.appendChild(node.cloneNode(true));
			}
			return frag;
		}

		function renderGallery() {
			const item = gallery[galleryIndex];
			if (!item) return;
			bodyEl.innerHTML = '';
			const wrap = document.createElement('div');
			wrap.className = 'relative overflow-hidden rounded-xl bg-stone-100 ring-1 ring-stone-200';
			const img = document.createElement('img');
			img.src = item.src;
			img.alt = item.alt;
			img.className = 'max-h-[min(70vh,720px)] w-full object-contain';
			img.loading = 'eager';
			wrap.appendChild(img);
			bodyEl.appendChild(wrap);
			counterEl.textContent = `${galleryIndex + 1} / ${gallery.length}`;
		}

		function setGalleryIndex(next) {
			if (!gallery.length) return;
			galleryIndex = (next + gallery.length) % gallery.length;
			renderGallery();
		}

		function openModal(opts) {
			titleEl.textContent = opts.title;
			bodyEl.innerHTML = '';
			navEl.classList.toggle('hidden', opts.mode !== 'gallery');
			dialog.dataset.mode = opts.mode || '';
			if (opts.mode === 'gallery') {
				renderGallery();
			} else if (opts.cloneId) {
				bodyEl.appendChild(cloneTpl(opts.cloneId));
			}
			dialog.showModal();
			document.body.style.overflow = 'hidden';
		}

		function closeModal() {
			dialog.close();
			document.body.style.overflow = '';
			delete dialog.dataset.mode;
		}

		dialog.addEventListener('close', () => {
			document.body.style.overflow = '';
			delete dialog.dataset.mode;
		});

		dialog.querySelector('[data-site-modal-backdrop]')?.addEventListener('click', closeModal);

		document.querySelectorAll('[data-site-modal-close]').forEach((btn) => {
			btn.addEventListener('click', () => closeModal());
		});

		document.querySelector('[data-gallery-prev]')?.addEventListener('click', () => setGalleryIndex(galleryIndex - 1));
		document.querySelector('[data-gallery-next]')?.addEventListener('click', () => setGalleryIndex(galleryIndex + 1));

		document.addEventListener('keydown', (e) => {
			if (!dialog.open || navEl.classList.contains('hidden')) return;
			if (e.key === 'ArrowLeft') setGalleryIndex(galleryIndex - 1);
			if (e.key === 'ArrowRight') setGalleryIndex(galleryIndex + 1);
		});

		document.querySelectorAll('[data-gallery-open]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const raw = btn.getAttribute('data-gallery-open');
				const i = raw == null ? 0 : parseInt(raw, 10);
				const max = Math.max(0, gallery.length - 1);
				galleryIndex = Number.isFinite(i) ? Math.min(Math.max(i, 0), max) : 0;
				openModal({ title: 'Project gallery', mode: 'gallery' });
			});
		});

		document.querySelectorAll('[data-legal-open]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const kind = btn.getAttribute('data-legal-open');
				if (kind === 'privacy') openModal({ title: 'Privacy policy', mode: 'clone', cloneId: 'tpl-privacy-root' });
				else if (kind === 'terms') openModal({ title: 'Terms of use', mode: 'clone', cloneId: 'tpl-terms-root' });
			});
		});

		const estimateForm = document.querySelector('form[name="estimate"]');
		if (estimateForm instanceof HTMLFormElement) {
			const formErrorEl = document.getElementById('est-form-error');
			const nameEl = estimateForm.querySelector('#est-fullname');
			const phoneEl = estimateForm.querySelector('#est-phone');
			const emailEl = estimateForm.querySelector('#est-email');

			const errorClasses = ['border-red-500', 'focus:border-red-500', 'focus:ring-red-500/25'];

			function setFieldError(el) {
				if (el instanceof HTMLInputElement) el.classList.add(...errorClasses);
			}

			function clearFieldError(el) {
				if (el instanceof HTMLInputElement) el.classList.remove(...errorClasses);
			}

			function clearErrors() {
				if (formErrorEl) {
					formErrorEl.classList.add('hidden');
					formErrorEl.textContent = '';
				}
				clearFieldError(nameEl);
				clearFieldError(phoneEl);
				clearFieldError(emailEl);
				if (emailEl instanceof HTMLInputElement) emailEl.setCustomValidity('');
			}

			function isValidEmailFormat(value) {
				var s = value.trim();
				if (!s) return true;
				return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(s);
			}

			[nameEl, phoneEl, emailEl].forEach((el) => {
				el?.addEventListener('input', () => {
					clearErrors();
				});
			});

			estimateForm.addEventListener('submit', async (e) => {
				e.preventDefault();
				clearErrors();

				var missing = [];
				var fullname = nameEl instanceof HTMLInputElement ? nameEl.value.trim() : '';
				if (!fullname) missing.push('Full name');

				var phone = phoneEl instanceof HTMLInputElement ? phoneEl.value.trim() : '';
				var email = emailEl instanceof HTMLInputElement ? emailEl.value.trim() : '';

				if (!phone && !email) {
					missing.push('Phone number or email');
					setFieldError(phoneEl);
					setFieldError(emailEl);
				}

				if (missing.length) {
					if (formErrorEl) {
						formErrorEl.textContent =
							'Missing required info: ' + missing.join(', ') + '.';
						formErrorEl.classList.remove('hidden');
						formErrorEl.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
					}
					if (!fullname) {
						setFieldError(nameEl);
						if (nameEl instanceof HTMLInputElement) nameEl.focus();
					} else if (!phone && !email) {
						if (phoneEl instanceof HTMLInputElement) phoneEl.focus();
						else if (emailEl instanceof HTMLInputElement) emailEl.focus();
					}
					return;
				}

				if (email) {
					if (emailEl instanceof HTMLInputElement) {
						if (!emailEl.checkValidity()) {
							setFieldError(emailEl);
							emailEl.reportValidity();
							return;
						}
						if (!isValidEmailFormat(email)) {
							setFieldError(emailEl);
							emailEl.setCustomValidity('Enter a valid email address.');
							emailEl.reportValidity();
							emailEl.setCustomValidity('');
							return;
						}
					}
				}

				const fd = new FormData(estimateForm);
				const params = new URLSearchParams();
				for (const pair of fd.entries()) {
					params.append(pair[0], pair[1]);
				}
				const body = params.toString();
				try {
					const res = await fetch(estimateForm.action || '/', {
						method: 'POST',
						headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
						body,
					});
					if (res.ok) {
						estimateForm.reset();
						titleEl.textContent = 'Thank You';
						bodyEl.innerHTML = '';
						bodyEl.appendChild(cloneTpl('tpl-success-root'));
						navEl.classList.add('hidden');
						dialog.showModal();
						document.body.style.overflow = 'hidden';
					} else {
						titleEl.textContent = 'Something went wrong';
						bodyEl.innerHTML =
							'<p class="text-sm text-stone-600">The form could not be submitted. Please try again or call Sage.</p>';
						navEl.classList.add('hidden');
						dialog.showModal();
						document.body.style.overflow = 'hidden';
					}
				} catch {
					titleEl.textContent = 'Something went wrong';
					bodyEl.innerHTML =
						'<p class="text-sm text-stone-600">Network error. Please check the connection or call Sage.</p>';
					navEl.classList.add('hidden');
					dialog.showModal();
					document.body.style.overflow = 'hidden';
				}
			});
		}

	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSiteModal);
	} else {
		initSiteModal();
	}
</script>
