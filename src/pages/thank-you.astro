---
import BaseLayout from '../layouts/BaseLayout.astro';
import FinancingCallout from '../components/FinancingCallout.astro';
---

<BaseLayout
	title="Thanks — Sage Home Improvements"
	description="Thanks for requesting a free in-home estimate. We'll be in touch shortly."
>
	<main class="mx-auto max-w-3xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
		<p class="text-sm font-semibold tracking-wide text-sage-700">Thank you</p>
		<h1 class="mt-2 text-3xl font-bold tracking-tight text-charcoal sm:text-4xl">
			Thanks for reaching out. My name is Terry Sage and I'll be calling you shortly.
		</h1>
		<p class="mt-4 text-base leading-relaxed text-stone-700">
			I'll be calling you personally to set up a time to come take a look. I've been doing this for 40 years and I still do every estimate myself. See you soon.
		</p>

		<FinancingCallout heading="While you wait, explore financing" />

		<div class="mt-8 flex flex-col gap-3 sm:flex-row">
			<a
				href="/"
				class="inline-flex w-full items-center justify-center rounded-lg bg-sage-600 px-4 py-3 text-center text-sm font-semibold text-white shadow-sm transition hover:bg-sage-700 sm:w-auto"
			>
				Back to the site
			</a>
		</div>
	</main>
</BaseLayout>

